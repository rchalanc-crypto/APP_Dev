{
  "rules": {
    ".read": false,
    ".write": false,
    "sessions": {
      ".read": true,
      "$session": {
        ".write": true,
        ".validate": "newData.hasChildren(['type', 'date', 'location', 'user', 'timestamp'])",
        "type":      { ".validate": "newData.isString() && (newData.val() == 'mtb' || newData.val() == 'kite')" },
        "date":      { ".validate": "newData.isString() && newData.val().matches(/^[0-9]{4}-[0-9]{2}-[0-9]{2}$/)" },
        "location":  { ".validate": "newData.isString() && newData.val().length >= 1 && newData.val().length <= 128" },
        "notes":     { ".validate": "newData.isString() && newData.val().length < 8192" },
        "user":      { ".validate": "newData.isString() && newData.val().length >= 1 && newData.val().length <= 64" },
        "timestamp": { ".validate": "newData.isString() && newData.val().length <= 40" },
        "$other":    { ".validate": false }
      }
    },
    "availability": {
      ".read": true,
      "$date": {
        "$user": {
          ".write": true,
          ".validate": "newData.isBoolean() || newData.hasChildren()",
          "am":  { ".validate": "newData.isBoolean()" },
          "pm":  { ".validate": "newData.isBoolean()" },
          "eve": { ".validate": "newData.isBoolean()" },
          "$other": { ".validate": false }
        }
      }
    }
  }
}
